{
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "deny": []
  },
  "auth": {
    "password": "CHANGE_ME"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/report-gate.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/debug-report-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/settings-guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
